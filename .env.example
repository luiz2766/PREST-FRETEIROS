# Environment Variables Configuration
# Copy this to .env (not committed) and provide actual values

# Supabase Configuration (Mandatory for history and storage)
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Gemini API Key (If required by any future feature)
GEMINI_API_KEY=your-gemini-api-key
